DISCORD_TOKEN=your_bot_token
CLIENT_ID=your_discord_application_id
GUILD_ID=your_discord_server_id
LOOT_CHANNEL_ID=discord_channel_id_dink_posts_loot_to
DEATH_CHANNEL_ID=discord_channel_id_dink_posts_deaths_to
GROUP_STORAGE_CHANNEL_ID=discord_channel_id_dink_posts_group_storage_transactions_to
BACKEND_URL=https://farmers-ironmen.up.railway.app
GROUP_NAME=your_group_name
GROUP_TOKEN=your_group_token
BANK_ALERT_CHANNEL_ID=discord_channel_id_to_post_bank_pings_to
SITE_URL=https://group-ironmen.vercel.app

# Optional -- bot personality (random/mentioned in-character replies).
# Leave GROQ_API_KEY unset to disable entirely. Get a free key at
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
PERSONALITY_TRIGGER_CHANCE=0.07
PERSONALITY_COOLDOWN_MS=30000
# Comma-separated channel IDs to restrict replies to; unset = every channel
# the bot can read.
PERSONALITY_CHANNEL_IDS=

# Optional -- occasionally roasts a death screenshot in-character using
# Groq's vision model, then @mentions the player (if their Discord ID is
# linked via the site's edit-member page). Reuses GROQ_API_KEY above; leave
# it unset to disable. DEATH_ROAST_CHANCE is the odds per death (0.3 = 30%).
GROQ_VISION_MODEL=qwen/qwen3.6-27b
DEATH_ROAST_CHANCE=0.3
